# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/
frontend/test-results/
frontend/output/

# next.js
.next/
out/

# production
build/*
!build/
!build/icon.svg
!build/icon.png
!build/icon.icns
!build/icon.ico
dist/
dist-electron/
backend/build/
backend/dist/
frontend/.next/

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.pub
.envrc

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
*.log

# local sqlite caches / debug artifacts
backend/data/*.db
backend/.tmp_*.xml
backend/*_debug.json
backend/*.spec
backend/scratch/
backend/scripts/*_output*.txt
frontend/test_output.txt
frontend/eslint_report.json
