EDGAR_IDENTITY=Your Name your@email.com
CORS_ORIGINS=https://your-vercel-project.vercel.app
ALLOWED_HOSTS=your-cloud-run-service.run.app,localhost,127.0.0.1
LOG_LEVEL=INFO
REQUEST_LOG_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Optional tuning flags
FINANCIALS_OPERATING_COMPANY_FILTER=true
FINANCIALS_REQUIRE_10K_PREFLIGHT=false
EXPOSE_IDENTITY_HINT=false
